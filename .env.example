# EverMemOS Cloud API (optional - app works without these in mock mode)
EVERMEM_API_KEY=your_api_key_here
EVERMEM_BASE_URL=https://api.evermemos.com/v1

# OpenAI API (optional - rule-based fallback is available)
OPENAI_API_KEY=your_openai_key_here

# Optional app password for shared deployments
EVERBRIEF_ACCESS_PASSWORD=your_shared_app_password
